# LLM provider connections (OpenAI-compatible APIs).
# Switch the primary provider with this single env var; the other configured providers are fallback.
# Copy this file to .env and fill in the values. .env is gitignored.

# OpenAI is the primary provider (issue 0031 — gpt-5.4-mini free daily tier).
# One key here is the ONLY secret a fresh clone needs for a live session.
PRIMARY_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini

# --- Groq (optional fallback) ---
# NOTE: llama-3.3-70b does NOT pass the judge calibration bench (VN over-scoring Δ=2.00,
# docs/audits/calibration-bench-2026-07-11-gpt-5.4-mini.md) — fallback is for availability,
# not judge quality.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=<your-groq-model-id>

# --- MiMo (legacy — endpoint retired 2026-06-03, kept only for self-hosted revivals) ---
# MIMO_API_KEY=
# MIMO_BASE_URL=https://<your-mimo-endpoint>/v1
# MIMO_MODEL=<your-mimo-model-id>

# --- Optional ---
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# --- Per-role routing (ADR 0010) ---
# Each agent role can override its provider, model, and temperature; unset roles inherit
# PRIMARY_PROVIDER + that provider's model + LLM_TEMPERATURE (the pre-0010 behavior).
# Roles: JUDGE, INTERVIEWER, SUPERVISOR, DIAGNOSTIC, PLANNER.
# The judge role is PINNED (ADR 0009a): it never fails over to another model, and changing
# ROLE_JUDGE_* is a judge change — `coach bench` must pass before it merges (ADR 0009).
# ROLE_JUDGE_PROVIDER=openai
# ROLE_JUDGE_MODEL=gpt-5.4-mini
# ROLE_JUDGE_TEMPERATURE=0.2
# ROLE_INTERVIEWER_PROVIDER=groq
# ROLE_INTERVIEWER_MODEL=openai/gpt-oss-120b
# ROLE_INTERVIEWER_TEMPERATURE=0.7
# ROLE_SUPERVISOR_TEMPERATURE=0.1
# ROLE_PLANNER_TEMPERATURE=0.4

# Per-model capability override: whether the provider's configured model accepts strict
# `response_format: json_schema` grammars. Unset defers to the verified default (True only for
# OpenAI today). Flip it when pointing a provider entry at a schema-capable compatible endpoint.
# OPENAI_SUPPORTS_JSON_SCHEMA=true
# GROQ_SUPPORTS_JSON_SCHEMA=false
# MIMO_SUPPORTS_JSON_SCHEMA=false

# Free-tier budget rail: the daily allowance is NOT exposed by the API (headers only carry the
# per-minute window), so every call is counted client-side into COACH_USAGE_LEDGER and
# `coach usage` / the bench report show the day's spend against LLM_DAILY_TOKEN_BUDGET.
# LLM_DAILY_TOKEN_BUDGET=2500000
# COACH_USAGE_LEDGER=logs/usage-ledger.jsonl
