# LLM provider connection (OpenAI-compatible API).
# MiMo is the primary provider; a Groq cutover is planned for 2026-06-03 (see docs/issues/0004).
# Copy this file to .env and fill in the values. .env is gitignored.

# --- Connection (required) ---
LLM_API_KEY=
LLM_BASE_URL=https://<your-mimo-endpoint>/v1
LLM_MODEL=<your-mimo-model-id>

# --- Optional ---
# Informational in slice 0; PRIMARY_PROVIDER-based switching arrives in issue 0004.
LLM_PROVIDER=mimo
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60
