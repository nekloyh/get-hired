# LLM provider connections (OpenAI-compatible APIs).
# Switch the primary provider with this single env var; the other configured provider is fallback.
# Copy this file to .env and fill in the values. .env is gitignored.

PRIMARY_PROVIDER=mimo

# --- MiMo ---
MIMO_API_KEY=
MIMO_BASE_URL=https://<your-mimo-endpoint>/v1
MIMO_MODEL=<your-mimo-model-id>

# --- Groq ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=<your-groq-model-id>

# --- Optional ---
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# OpenAI (primary since issue 0031 — gpt-5.4-mini free daily tier)
# PRIMARY_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4-mini

# Free-tier budget rail: the daily allowance is NOT exposed by the API (headers only carry the
# per-minute window), so every call is counted client-side into COACH_USAGE_LEDGER and
# `coach usage` / the bench report show the day's spend against LLM_DAILY_TOKEN_BUDGET.
# LLM_DAILY_TOKEN_BUDGET=2500000
# COACH_USAGE_LEDGER=logs/usage-ledger.jsonl
